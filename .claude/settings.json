      "Bash(vercel --prod*)",
      "Bash(railway up --environment production*)",
      "Bash(railway up -e production*)",
      "Bash(heroku apps:destroy*)",
      "Bash(fly deploy*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .git*)",
      "Bash(gh pr merge*)",
      "Bash(gh release create*)",
      "Bash(gh repo delete*)",
